{
  "name": "@rtorcato/api-openapi-express",
  "version": "1.0.0",
  "description": "Express router that serves Scalar API docs from an OpenAPI spec object.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@rtorcato/api-openapi": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "swagger-jsdoc": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "swagger-jsdoc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.1",
    "express": "^5.1.0",
    "supertest": "^7.1.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "express",
    "openapi",
    "scalar",
    "swagger",
    "docs",
    "middleware"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-openapi-express"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-openapi-express#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
