{
  "name": "@rtorcato/api-config",
  "version": "0.0.0",
  "description": "Load and validate environment variables with dotenv + zod for Node API projects.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@rtorcato/js-common": "^2.8.1",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "env",
    "dotenv",
    "zod",
    "config",
    "environment-variables"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-config"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-config#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
