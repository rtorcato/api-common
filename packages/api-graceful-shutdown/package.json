{
	"name": "@rtorcato/api-graceful-shutdown",
	"version": "1.0.0",
	"description": "Framework-agnostic graceful shutdown for Node API servers — SIGTERM/SIGINT drain with ordered cleanup hooks and a hard timeout.",
	"type": "module",
	"license": "MIT",
	"author": "Richard Torcato",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "~6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"api",
		"nodejs",
		"typescript",
		"graceful-shutdown",
		"sigterm",
		"lifecycle",
		"kubernetes"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rtorcato/api-common.git",
		"directory": "packages/api-graceful-shutdown"
	},
	"homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-graceful-shutdown#readme",
	"bugs": {
		"url": "https://github.com/rtorcato/api-common/issues"
	}
}
