{
  "name": "@rtorcato/api-timeout",
  "version": "0.0.0",
  "description": "Framework-agnostic per-request timeout for Node API projects — race a promise against a deadline and reject with a ServiceUnavailableError.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@rtorcato/api-errors": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "timeout",
    "deadline",
    "http"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-timeout"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-timeout#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
