{
  "name": "@rtorcato/api-logger",
  "version": "1.0.0",
  "description": "Framework-agnostic pino logger factory for Node API projects.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@rtorcato/js-common": "^2.8.1",
    "pino": "^9.5.0"
  },
  "peerDependencies": {
    "pino-pretty": "^13.0.0"
  },
  "peerDependenciesMeta": {
    "pino-pretty": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "pino",
    "logger",
    "logging"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-logger"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-logger#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
