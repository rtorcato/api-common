{
  "name": "@rtorcato/api-validation",
  "version": "0.0.0",
  "description": "Zod request validation helpers with pretty error formatting for Node API projects.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@rtorcato/api-errors": "workspace:*",
    "zod-error": "^2.0.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "zod",
    "validation",
    "request-validation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-validation"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-validation#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
