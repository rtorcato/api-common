{
  "name": "@rtorcato/api-errors",
  "version": "0.0.0",
  "description": "Framework-agnostic HTTP error classes for Node.js APIs.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
