{
  "name": "@rtorcato/api-response",
  "version": "1.0.0",
  "description": "Consistent success-response envelope and zod schema helper for Node API projects.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@rtorcato/api-errors": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "response",
    "envelope",
    "zod",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-response"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-response#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
