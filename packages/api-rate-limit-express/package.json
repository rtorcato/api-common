{
	"name": "@rtorcato/api-rate-limit-express",
	"version": "2.0.0",
	"description": "Express middleware for @rtorcato/api-rate-limit (sliding-window rate limiter).",
	"type": "module",
	"license": "MIT",
	"author": "Richard Torcato",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@rtorcato/api-errors": "workspace:*",
		"@rtorcato/api-express-utils": "workspace:*",
		"@rtorcato/api-rate-limit": "workspace:*"
	},
	"peerDependencies": {
		"express": "^4.18.0 || ^5.0.0"
	},
	"devDependencies": {
		"@types/express": "^5.0.0",
		"@types/supertest": "^7.2.1",
		"express": "^5.1.0",
		"supertest": "^7.1.0",
		"typescript": "~6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"api",
		"nodejs",
		"typescript",
		"express",
		"middleware",
		"rate-limit",
		"http"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rtorcato/api-common.git",
		"directory": "packages/api-rate-limit-express"
	},
	"homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-rate-limit-express#readme",
	"bugs": {
		"url": "https://github.com/rtorcato/api-common/issues"
	}
}
