{
  "name": "@rtorcato/api-rate-limit",
  "version": "1.0.0",
  "description": "Framework-agnostic sliding-window rate limiter for Node API projects, with a pluggable store (in-memory or Redis).",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "rate-limit",
    "rate-limiter",
    "sliding-window"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-rate-limit"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-rate-limit#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
