{
	"name": "@rtorcato/api-health",
	"version": "0.1.0",
	"description": "Framework-agnostic liveness/readiness health-check registry for Node API projects.",
	"type": "module",
	"license": "MIT",
	"author": "Richard Torcato",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"api",
		"nodejs",
		"typescript",
		"health",
		"healthcheck",
		"liveness",
		"readiness"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rtorcato/api-common.git",
		"directory": "packages/api-health"
	},
	"homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-health#readme",
	"bugs": {
		"url": "https://github.com/rtorcato/api-common/issues"
	}
}
