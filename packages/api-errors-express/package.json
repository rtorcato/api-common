    "supertest": "^7.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "express",
    "middleware",
    "error-handling",
    "http"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-errors-express"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-errors-express#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
