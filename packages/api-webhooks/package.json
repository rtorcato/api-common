{
  "name": "@rtorcato/api-webhooks",
  "version": "0.0.0",
  "description": "Framework-agnostic webhook signature verification (HMAC) for Node API projects.",
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "nodejs",
    "typescript",
    "webhook",
    "webhooks",
    "hmac",
    "signature"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/api-common.git",
    "directory": "packages/api-webhooks"
  },
  "homepage": "https://github.com/rtorcato/api-common/tree/main/packages/api-webhooks#readme",
  "bugs": {
    "url": "https://github.com/rtorcato/api-common/issues"
  }
}
