{
  "name": "api-common",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "vitest run --config vitest.coverage.mjs --coverage",
    "build": "pnpm -r build",
    "check:exports": "pnpm -r --filter \"./packages/*\" exec publint && pnpm -r --filter \"./packages/*\" exec attw --pack . --profile esm-only --ignore-rules internal-resolution-error",
    "gen:readme": "node scripts/gen-readme-packages.mjs",
    "check:readme": "node scripts/gen-readme-packages.mjs --check",
    "check:docs": "node scripts/check-docs-coverage.mjs",
    "sync:agents": "node scripts/sync-agents.mjs",
    "check:agents": "node scripts/sync-agents.mjs --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish",
    "prepare": "is-ci || husky",
    "commit": "cz"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@biomejs/biome": "^2.5.5",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@rtorcato/js-tooling": "^2.56.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.2.0",
    "publint": "0.3.22",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,md,yml,yaml}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
